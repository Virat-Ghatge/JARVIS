# Environment variables for JARVIS
# Copy this file to .env and add your actual API keys

# OpenWeatherMap API Key (for weather feature)
# Get yours free at: https://openweathermap.org/api
WEATHER_API_KEY=your_weather_api_key_here

# Google Gemini API Key (for AI-powered responses)
# Get yours free at: https://aistudio.google.com/app/apikey
# Free tier: 1,500 requests/day, 15 requests/minute
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (for Q&A — Llama 3.1, free tier: 14,400 req/day)
# Get yours free at: https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: Force online mode (if internet check fails but you are online)
# Set to 'true' if JARVIS incorrectly shows "Offline"
# JARVIS_FORCE_ONLINE=false
